generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Task {
  id          String   @id @default(uuid())
  title       String
  pillar      String
  agentId     String
  status      String
  isDelegated Boolean  @default(false)
  createdAt   DateTime @default(now())
}
